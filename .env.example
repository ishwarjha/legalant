# KANOON_API_TOKEN=your_kanoon_api_token_here

# Phase 2B — add when Finanvo MCA API is activated
# FINANVO_ACCESS_KEY=your_finanvo_access_key_here
# FINANVO_ACCESS_SECRET=your_finanvo_access_secret_here
