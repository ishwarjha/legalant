{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LegalAnt Document Index",
  "description": "Index of all documents in a matter. Generated by the Document Indexer agent.",
  "type": "object",
  "required": ["matter_id", "documents"],
  "properties": {
    "matter_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by_agent": { "type": "string" },
    "agent_version": { "type": "string" },
    "reviewed_by_human": { "type": "boolean", "default": false },
    "review_timestamp": { "type": ["string", "null"], "format": "date-time" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_id", "filename", "document_type"],
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Unique document identifier within the matter",
            "examples": ["DOC-001"]
          },
          "filename": { "type": "string" },
          "filepath": {
            "type": "string",
            "description": "Relative path from matter root"
          },
          "document_type": {
            "type": "string",
            "enum": [
              "Agreement",
              "Amendment",
              "Side Letter",
              "MOU",
              "Term Sheet",
              "Board Resolution",
              "Shareholder Resolution",
              "Power of Attorney",
              "Corporate Charter",
              "Certificate of Incorporation",
              "Annual Return",
              "Financial Statement",
              "Audit Report",
              "Valuation Report",
              "Court Order",
              "Arbitral Award",
              "Pleading",
              "Affidavit",
              "Legal Notice",
              "Reply to Notice",
              "Correspondence",
              "Regulatory Filing",
              "Licence/Permit",
              "Title Document",
              "IP Registration",
              "Employment Document",
              "Other"
            ]
          },
          "date_of_document": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Date appearing on the document itself"
          },
          "date_received": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Date the document was received by the firm"
          },
          "parties_mentioned": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ocr_processed": { "type": "boolean", "default": false },
          "ocr_file_path": { "type": ["string", "null"] },
          "extracted_text_path": { "type": ["string", "null"] },
          "language": {
            "type": "string",
            "default": "en",
            "description": "ISO 639-1 language code; use 'hi' for Hindi, 'en' for English"
          },
          "page_count": { "type": ["integer", "null"], "minimum": 1 },
          "file_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
          "checksum_sha256": {
            "type": ["string", "null"],
            "description": "SHA-256 hash for integrity verification"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "summary": {
            "type": ["string", "null"],
            "description": "One-paragraph AI-generated summary"
          },
          "key_clauses": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Notable clause titles or topics identified"
          },
          "is_confidential": { "type": "boolean", "default": true },
          "privilege": {
            "type": "string",
            "enum": ["Privileged", "Not Privileged", "Unclear"],
            "default": "Unclear",
            "description": "Legal professional privilege status"
          },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "total_documents": {
      "type": "integer",
      "description": "Total count of documents in index"
    },
    "document_types_summary": {
      "type": "object",
      "description": "Count of documents by type",
      "additionalProperties": { "type": "integer" }
    }
  },
  "additionalProperties": false
}
